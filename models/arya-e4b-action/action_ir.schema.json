{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Arya Action IR v1",
  "type": "object",
  "required": ["version", "route", "task_type", "risk_level", "needs_confirmation", "slots", "plan"],
  "additionalProperties": false,
  "properties": {
    "version": {"const": "arya.action.v1"},
    "route": {"enum": ["execute", "clarify", "refuse", "escalate"]},
    "task_type": {"enum": ["simple", "compound", "exploratory", "unsafe", "unknown"]},
    "risk_level": {"enum": ["low", "medium", "high", "blocked"]},
    "needs_confirmation": {"type": "boolean"},
    "user_visible_summary": {"type": "string", "maxLength": 240},
    "slots": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean", "null"]}},
    "clarification": {"type": "string", "maxLength": 300},
    "refusal_reason": {"type": "string", "maxLength": 120},
    "plan": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["step_id", "action", "args", "effect"],
        "additionalProperties": false,
        "properties": {
          "step_id": {"type": "string", "pattern": "^s[1-8]$"},
          "action": {
            "enum": [
              "open_app", "open_messaging_chat", "prepare_message", "commit_message",
              "search_browser", "read_visible_content", "summarize_visible_content",
              "get_device_info", "take_screenshot", "system_back", "system_home",
              "wait_for_ui", "clarify_contact", "finish"
            ]
          },
          "args": {"type": "object"},
          "effect": {
            "enum": [
              "observation", "navigation", "prepare_write", "external_message_commit",
              "external_call_commit", "settings_mutation", "none"
            ]
          },
          "on_fail": {"enum": ["ask_user", "repair", "escalate", "stop"]}
        }
      }
    }
  }
}
